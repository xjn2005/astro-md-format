{
  "name": "@cavillxu/astro-md-format",
  "version": "0.1.0",
  "description": "Astro integration for formatting Chinese technical Markdown typography.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
