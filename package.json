{
  "name": "@cavillxu/astro-md-format",
  "version": "0.1.3",
  "description": "Astro Markdown formatting plugin for Chinese technical writing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/xjn2005/astro-md-format",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xjn2005/astro-md-format.git"
  },
  "bugs": {
    "url": "https://github.com/xjn2005/astro-md-format/issues"
  },
  "author": "Jianing Xu",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
